algoritmo "F1F2F3"
var
   n: real

inicio
   escreva("insira um n·mero para saber se ele ķ F1, F2 ou F3: ")
   leia(n)
   se (n > 100) entao
      escreval("O n·mero",n," ķ F3")
   senao
      se ( (n > 10) e (n <= 100) ) entao
         escreval("O n·mero",n," ķ F2")
      senao
       escreval("O n·mero",n," ķ F1")
       fimse
       fimse
fimalgoritmo