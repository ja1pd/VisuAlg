algoritmo "tempodevida"
var
ano,mes,dia,total:inteiro
inicio
escreva("Insira a quantidade de anos de vida da pessoa: ")
leia(ano)
escreva("Insira a quantidade de meses de vida da pessoa: ")
leia(mes)
escreva("Insira a quantidade de dias de vida da pessoa: ")
leia(dia)
total <- ((ano * 360) + (mes * 30) + dia))
escreval( "Aquantidade de dias de vida dessa pessoa é:",total)
fimalgoritmo