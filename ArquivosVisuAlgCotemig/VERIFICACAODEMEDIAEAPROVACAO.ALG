Algoritmo "verificacaodemediaeaprovacao"
// Disciplina   : [Linguagem e Lógica de Programaçăo]
// Professor   : Antonio Carlos Nicolodi 
// Descriçăo   : Aqui vocę descreve o que o programa faz! (funçăo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 01/06/2023
Var
// Seçăo de Declaraçőes das variáveis 
nt1,nt2,nt3,md: real


Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
escreva("Escreva a primeira nota do aluno:")
leia(nt1)
escreva("Escreva a segunda nota do aluno:")
leia(nt2)
escreva("Escreva a terceira nota do aluno:")
leia(nt3)
md <- (nt1+nt2+nt3)/3
se(md=10)entao
escreva("Aprovado com Louvor!")
senao
se(md >= 7) entao
escreva("Aprovado")
senao
escreva("Reprovado")
fimse
fimse
Fimalgoritmo
